      "Bash(where.exe:*)",
      "Bash(curl:*)",
      "Bash(curl -s:*)",
      "Bash(curl -X POST:*)",

      "Bash(tasklist)",
      "Bash(taskkill:*)",

      "Read(P:\\Obsidian\\Martin\\03_Projekte\\Baupilot\\**)",
      "Read(P:\\Datenuebergabe FLI\\**)",
      "Read(P:\\Datenübergabe FLI\\**)",
      "Read(C:\\SPARK\\spark-baupilot\\**)",
      "Read(C:\\Tools\\baupilot.work\\**)",
      "Read(C:\\Tools\\claude-sandbox\\**)",

      "Write(C:\\SPARK\\spark-baupilot\\**)",
