      "Bash(docker restart baupilot-api)",
      "Bash(docker restart baupilot-frontend)",
      "Bash(docker restart baupilot-litellm)",
      "Bash(MSYS_NO_PATHCONV=1 docker:*)",

      "Bash(pwsh -NoProfile -ExecutionPolicy Bypass -File:*)",
      "Bash(pwsh -NoProfile -Command:*)",
      "Bash(pwsh --version)",
      "Bash(powershell -Command:*)",
      "Bash(powershell -NoProfile -Command:*)",
