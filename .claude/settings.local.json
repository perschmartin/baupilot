  "permissions": {
    "allow": [
      "Bash(docker exec baupilot-api:*)",
      "Bash(docker exec baupilot-postgres:*)",
      "Bash(docker exec baupilot-frontend:*)",
      "Bash(docker exec baupilot-minio:*)",
