# BauPilot — Umgebungsvariablen
# Kopieren als .env und anpassen

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5436
POSTGRES_USER=baupilot
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=baupilot

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6345
QDRANT_GRPC_PORT=6346

# === MinIO ===
MINIO_HOST=localhost
MINIO_API_PORT=9004
MINIO_CONSOLE_PORT=9005
MINIO_ROOT_USER=baupilot
MINIO_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION

# === LiteLLM ===
LITELLM_HOST=localhost
LITELLM_PORT=4002

# === Ollama (gemeinsam mit SPARK/SPARK-BNB) ===
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# === BauPilot API ===
API_HOST=0.0.0.0
API_PORT=8110
API_LOG_LEVEL=info
API_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
API_CORS_ORIGINS=["http://localhost:8091","https://fli.baupilot.work"]

# === Frontend ===
FRONTEND_PORT=8091

# === Allgemein ===
ENVIRONMENT=development
